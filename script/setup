#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: script/setup [options]

Set up this shell config on a remote Linux host. Intended for disposable or
semi-disposable SSH environments on cloud VMs and GitHub Codespaces.

The repo's tracked config files (zshrc, zshenv, bashrc, gitconfig) are not
modified or symlinked. Instead, small shim files are written to $HOME that
export the needed env (SHELL_CONFIG_DIR, DOTFILES_DIR, PATH for git/ and
tmux/) and source the repo's reference files.

Options:
  --minimal               Install only the base deps (zsh, bash, tmux, git,
                          curl, fzf, ripgrep, bat).
  --with-language-tools   Install optional linters/formatters and Python deps
                          for git-commit-generator.
  --dotfiles-dir DIR      Set DOTFILES_DIR in the generated shims. Defaults to
                          $HOME/.dotfiles.
  --no-shims              Skip writing shim files to $HOME (deps only).
  --dry-run               Print commands without running them.
  -h, --help              Show this help.
USAGE
}

log() {
  printf '==> %s\n' "$*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

run() {
  if [ "${DRY_RUN}" = "1" ]; then
    printf '+'
    printf ' %q' "$@"
    printf '\n'
  else
    "$@"
  fi
}

have() {
  command -v "$1" >/dev/null 2>&1
}

as_root() {
  if [ "$(id -u)" -eq 0 ]; then
    run "$@"
  elif have sudo; then
    run sudo "$@"
  else
    die "this step needs root privileges; install sudo or run as root"
  fi
}

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
SHELL_CONFIG_DIR="$(cd -- "${SCRIPT_DIR}/.." && pwd -P)"

DRY_RUN=0
WRITE_SHIMS=1
INSTALL_LANGUAGE_TOOLS=0
DOTFILES_DIR_OVERRIDE=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --minimal)
      INSTALL_LANGUAGE_TOOLS=0
      ;;
    --with-language-tools)
      INSTALL_LANGUAGE_TOOLS=1
      ;;
    --no-shims)
      WRITE_SHIMS=0
      ;;
    --dotfiles-dir)
      [ "$#" -ge 2 ] || die "--dotfiles-dir requires an argument"
      DOTFILES_DIR_OVERRIDE="$2"
      shift
      ;;
    --dotfiles-dir=*)
      DOTFILES_DIR_OVERRIDE="${1#--dotfiles-dir=}"
      ;;
    --dry-run)
      DRY_RUN=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
  shift
done

case "$(uname -s)" in
  Linux)
    ;;
  *)
    die "this setup script is only intended for remote Linux hosts"
    ;;
esac

DOTFILES_DIR_VALUE="${DOTFILES_DIR_OVERRIDE:-${HOME}/.dotfiles}"

SHIM_MARKER="# Generated by shell/script/setup -- do not edit (re-run setup to update)"

BASE_APT_PACKAGES=(
  bash
  bat
  ca-certificates
  curl
  fzf
  git
  ripgrep
  tmux
  zsh
)

LANG_APT_PACKAGES=(
  jq
  nodejs
  npm
  python3-pip
  shellcheck
  shfmt
  universal-ctags
  yamllint
)

BASE_DNF_PACKAGES=(
  bash
  bat
  ca-certificates
  curl
  fzf
  git
  ripgrep
  tmux
  zsh
)

LANG_DNF_PACKAGES=(
  ShellCheck
  ctags
  jq
  nodejs
  npm
  python3-pip
  shfmt
  yamllint
)

detect_package_manager() {
  if have apt-get; then
    printf 'apt\n'
  elif have dnf; then
    printf 'dnf\n'
  elif have yum; then
    printf 'yum\n'
  else
    die "could not find apt-get, dnf, or yum"
  fi
}

install_packages() {
  local manager="$1"
  shift

  if [ "$#" -eq 0 ]; then
    return
  fi

  case "${manager}" in
    apt)
      as_root apt-get update
      as_root env DEBIAN_FRONTEND=noninteractive apt-get install -y "$@"
      ;;
    dnf)
      as_root dnf install -y "$@"
      ;;
    yum)
      as_root yum install -y "$@"
      ;;
    *)
      die "unsupported package manager: ${manager}"
      ;;
  esac
}

install_python_deps() {
  local pkgs=(openai pyxdg pyyaml)

  if have pipx; then
    local p
    for p in "${pkgs[@]}"; do
      run pipx install "${p}" || warn "pipx failed for ${p}; continuing"
    done
  elif have python3 && python3 -m pip --version >/dev/null 2>&1; then
    run python3 -m pip install --user --upgrade "${pkgs[@]}"
  else
    warn "python3 pip is not available; skipping ${pkgs[*]}"
  fi
}

install_ruby_deps() {
  if have gem; then
    run gem install --user-install tmuxinator
  else
    warn "gem is not available; skipping tmuxinator"
  fi
}

install_language_tools() {
  install_python_deps
  install_ruby_deps
}

pkg_provides_eza() {
  case "${PACKAGE_MANAGER}" in
    apt)
      apt-cache show eza >/dev/null 2>&1
      ;;
    dnf|yum)
      "${PACKAGE_MANAGER}" info eza >/dev/null 2>&1
      ;;
  esac
}

install_eza_binary() {
  local arch url install_dir tmpdir
  case "$(uname -m)" in
    x86_64)
      arch="x86_64-unknown-linux-gnu"
      ;;
    aarch64|arm64)
      arch="aarch64-unknown-linux-gnu"
      ;;
    *)
      warn "unsupported arch for eza prebuilt binary: $(uname -m); install manually"
      return
      ;;
  esac

  url="https://github.com/eza-community/eza/releases/latest/download/eza_${arch}.tar.gz"

  if [ "$(id -u)" -eq 0 ] || [ -w /usr/local/bin ]; then
    install_dir=/usr/local/bin
  else
    install_dir="${HOME}/.local/bin"
    run mkdir -p "${install_dir}"
  fi

  if [ "${DRY_RUN}" = "1" ]; then
    printf '+ curl -fL %q -o eza.tar.gz && install eza -> %q\n' "${url}" "${install_dir}/eza"
    return
  fi

  tmpdir="$(mktemp -d)"
  if ! curl -fL --output "${tmpdir}/eza.tar.gz" "${url}"; then
    warn "failed to download eza from ${url}; install manually"
    rm -rf "${tmpdir}"
    return
  fi

  if ! tar -xzf "${tmpdir}/eza.tar.gz" -C "${tmpdir}"; then
    warn "failed to extract eza tarball; install manually"
    rm -rf "${tmpdir}"
    return
  fi

  if [ "${install_dir}" = "/usr/local/bin" ]; then
    as_root install -m 0755 "${tmpdir}/eza" /usr/local/bin/eza
  else
    install -m 0755 "${tmpdir}/eza" "${install_dir}/eza"
    log "Installed eza to ${install_dir}/eza (ensure ${install_dir} is on PATH)"
  fi

  rm -rf "${tmpdir}"
}

install_eza() {
  if have eza; then
    log "eza already installed"
    return
  fi

  if pkg_provides_eza; then
    log "Installing eza via ${PACKAGE_MANAGER}"
    install_packages "${PACKAGE_MANAGER}" eza
    return
  fi

  log "eza not in ${PACKAGE_MANAGER} repos; installing prebuilt binary"
  install_eza_binary
}

ensure_dotfiles_stub() {
  local stub="${DOTFILES_DIR_VALUE}/env/setup.sh"

  if [ -e "${stub}" ]; then
    return
  fi

  log "Creating DOTFILES_DIR stub at ${stub}"
  run mkdir -p "$(dirname "${stub}")"

  if [ "${DRY_RUN}" = "1" ]; then
    printf '+ write empty stub %q\n' "${stub}"
    return
  fi

  cat >"${stub}" <<EOF
# Auto-generated by shell/script/setup.
# Empty stub so the unconditional source in zshenv/bashrc does not error
# on hosts where the parent dotfiles tree provides no env/setup.sh.
EOF
}

starts_with_marker() {
  local path="$1"
  [ -f "${path}" ] || return 1
  IFS= read -r first_line <"${path}" || return 1
  [ "${first_line}" = "${SHIM_MARKER}" ]
}

backup_if_needed() {
  local path="$1"

  if [ ! -e "${path}" ] && [ ! -L "${path}" ]; then
    return
  fi

  if starts_with_marker "${path}"; then
    return
  fi

  local backup
  backup="${path}.bak.$(date +%Y%m%d%H%M%S)"
  log "Backing up ${path} -> ${backup}"
  run mv "${path}" "${backup}"
}

write_file() {
  local path="$1"
  local content="$2"

  if [ "${DRY_RUN}" = "1" ]; then
    printf '+ write %q (%d bytes)\n' "${path}" "${#content}"
    return
  fi

  printf '%s' "${content}" >"${path}"
}

write_zshenv_shim() {
  local path="${HOME}/.zshenv"
  backup_if_needed "${path}"
  log "Writing ${path}"
  write_file "${path}" "\
${SHIM_MARKER}
export SHELL_CONFIG_DIR=\"${SHELL_CONFIG_DIR}\"
export DOTFILES_DIR=\"\${DOTFILES_DIR:-${DOTFILES_DIR_VALUE}}\"
case \":\$PATH:\" in
  *\":\$SHELL_CONFIG_DIR/git:\"*) ;;
  *) export PATH=\"\$SHELL_CONFIG_DIR/git:\$SHELL_CONFIG_DIR/tmux:\$PATH\" ;;
esac
[ -r \"\$SHELL_CONFIG_DIR/zshenv\" ] && . \"\$SHELL_CONFIG_DIR/zshenv\"
"
}

write_zshrc_shim() {
  local path="${HOME}/.zshrc"
  backup_if_needed "${path}"
  log "Writing ${path}"
  write_file "${path}" "\
${SHIM_MARKER}
[ -r \"\$SHELL_CONFIG_DIR/zshrc\" ] && . \"\$SHELL_CONFIG_DIR/zshrc\"
"
}

write_bashrc_shim() {
  local path="${HOME}/.bashrc"
  backup_if_needed "${path}"
  log "Writing ${path}"
  write_file "${path}" "\
${SHIM_MARKER}
export SHELL_CONFIG_DIR=\"${SHELL_CONFIG_DIR}\"
export DOTFILES_DIR=\"\${DOTFILES_DIR:-${DOTFILES_DIR_VALUE}}\"
case \":\$PATH:\" in
  *\":\$SHELL_CONFIG_DIR/git:\"*) ;;
  *) export PATH=\"\$SHELL_CONFIG_DIR/git:\$SHELL_CONFIG_DIR/tmux:\$PATH\" ;;
esac
[ -r \"\$SHELL_CONFIG_DIR/bashrc\" ] && . \"\$SHELL_CONFIG_DIR/bashrc\"
"
}

configure_gitconfig_include() {
  local repo_gitconfig="${SHELL_CONFIG_DIR}/gitconfig"
  local existing

  if ! have git; then
    warn "git not installed yet; skipping gitconfig include (re-run after install)"
    return
  fi

  if existing="$(git config --global --get-all include.path 2>/dev/null)"; then
    if printf '%s\n' "${existing}" | grep -Fxq "${repo_gitconfig}"; then
      log "git include.path already set to ${repo_gitconfig}; leaving as is"
      return
    fi
  fi

  log "Adding git include.path -> ${repo_gitconfig}"
  run git config --global --add include.path "${repo_gitconfig}"
}

PACKAGE_MANAGER="$(detect_package_manager)"

log "Using package manager: ${PACKAGE_MANAGER}"

case "${PACKAGE_MANAGER}" in
  apt)
    packages=("${BASE_APT_PACKAGES[@]}")
    if [ "${INSTALL_LANGUAGE_TOOLS}" = "1" ]; then
      packages+=("${LANG_APT_PACKAGES[@]}")
    fi
    ;;
  dnf|yum)
    packages=("${BASE_DNF_PACKAGES[@]}")
    if [ "${INSTALL_LANGUAGE_TOOLS}" = "1" ]; then
      packages+=("${LANG_DNF_PACKAGES[@]}")
    fi
    ;;
esac

log "Installing OS packages"
install_packages "${PACKAGE_MANAGER}" "${packages[@]}"

log "Ensuring eza is installed"
install_eza

if [ "${INSTALL_LANGUAGE_TOOLS}" = "1" ]; then
  log "Installing optional language tools"
  install_language_tools
fi

if ! have delta; then
  warn "git-delta is not installed (not in default apt/dnf repos);"
  warn "install from https://github.com/dandavison/delta/releases for syntax-highlighted diffs"
fi

if [ "${WRITE_SHIMS}" = "1" ]; then
  log "Ensuring DOTFILES_DIR stub at ${DOTFILES_DIR_VALUE}/env/setup.sh"
  ensure_dotfiles_stub

  log "Writing shim files to \$HOME"
  write_zshenv_shim
  write_zshrc_shim
  write_bashrc_shim

  log "Configuring ~/.gitconfig include"
  configure_gitconfig_include
fi

log "Done"

if [ "${WRITE_SHIMS}" = "1" ]; then
  cat <<EOF

Open a new shell to pick up the new config, or run:

    exec \$SHELL -l

If you'd like zsh as your login shell, run: chsh -s "\$(command -v zsh)"
EOF
fi
